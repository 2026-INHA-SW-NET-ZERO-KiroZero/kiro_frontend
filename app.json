{
  "expo": {
    "name": "KiroZero",
    "slug": "kiro-zero",
    "version": "1.0.0",
    "scheme": "kirozero",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.l2juhan.kirozero",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.l2juhan.kirozero",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "owner": "l2juhan",
    "extra": {
      "eas": {
        "projectId": "4f7c93f4-5534-4ae8-98fb-d4bfb4a47519"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-splash-screen",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "모임 평가에 올릴 완성·잔반 사진을 선택하기 위해 사진 보관함 접근이 필요해요."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
